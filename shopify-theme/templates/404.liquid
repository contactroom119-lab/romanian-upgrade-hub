{%- comment -%} 404 — ports the React NotFoundComponent. {%- endcomment -%}
<section class="r119-section r119-container" style="min-height: 60vh; display: grid; place-items: center; text-align: center;">
  <div style="max-width: 28rem;">
    <h1 class="font-display" style="font-size: 5rem; line-height: 1; color: var(--primary);">404</h1>
    <h2 class="font-display" style="margin-top: 1rem; font-size: 1.5rem;">Page not found</h2>
    <p style="margin-top: 0.5rem; color: var(--muted-foreground);">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <div style="margin-top: 1.5rem;">
      <a href="{{ routes.root_url }}" class="r119-btn r119-btn--primary">Go home</a>
    </div>
  </div>
</section>
